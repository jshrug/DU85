# Copy this file to `.env` and fill in values from your own Firebase project.
# Never commit your real `.env`.

# --- Firebase web config (Firebase Console > Project settings > Your apps) ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- Cohort settings ---
# Firestore document id under `cohorts/{COHORT_ID}` that scopes all data.
VITE_COHORT_ID=default
# Email domain allowed to sign in. Lowercase, no leading "@".
VITE_ALLOWED_EMAIL_DOMAIN=du.edu

# --- Email-link sign-in ---
# Where the email-link redirect lands. In production set this to your deployed
# origin (e.g. https://yourapp.vercel.app). Leave blank locally to fall back to
# window.location.origin.
VITE_AUTH_REDIRECT_URL=

# --- Explore feed (optional) ---
# Published Google Sheet CSV URL. The /api/sheets serverless function proxies
# this to avoid CORS issues. Leave blank if you are not using Explore.
VITE_EXPLORE_SHEET_URL=
